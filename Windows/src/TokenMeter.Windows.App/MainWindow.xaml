<Window
    x:Class="TokenMeter.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Token Meter">
    <NavigationView x:Name="Navigation"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    IsPaneOpen="False"
                    PaneDisplayMode="LeftCompact"
                    SelectionChanged="Navigation_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="DashboardItem" x:Uid="DashboardNavigation" Tag="dashboard">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="SettingsItem" x:Uid="SettingsNavigation" Tag="settings">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
