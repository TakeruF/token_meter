<Page
    x:Class="TokenMeter.Windows.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="880" HorizontalAlignment="Stretch">
            <TextBlock x:Uid="SettingsTitle" Style="{StaticResource TitleTextBlockStyle}" />

            <StackPanel Spacing="10">
                <TextBlock x:Uid="ProvidersTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                    <StackPanel Spacing="14">
                        <ToggleSwitch x:Name="ClaudeToggle" Header="Claude Code" Toggled="Provider_Toggled" />
                        <ToggleSwitch x:Name="CodexToggle" Header="Codex" Toggled="Provider_Toggled" />
                        <ToggleSwitch x:Name="CopilotToggle" Header="Copilot CLI" Toggled="Provider_Toggled" />
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <ToggleSwitch x:Name="ClaudeOAuthToggle" x:Uid="ClaudeOAuthToggle" Toggled="MonitorSetting_Toggled" />
                        <TextBlock x:Uid="ClaudeCredentialNotice" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock x:Uid="DisplayTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                    <StackPanel Spacing="14">
                        <ToggleSwitch x:Name="FiveHourToggle" x:Uid="FiveHourToggle" Toggled="DisplaySetting_Toggled" />
                        <ToggleSwitch x:Name="WeeklyToggle" x:Uid="WeeklyToggle" Toggled="DisplaySetting_Toggled" />
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock x:Uid="RefreshIntervalLabel" VerticalAlignment="Center" />
                            <ComboBox x:Name="RefreshIntervalBox" Grid.Column="1" MinWidth="150" SelectionChanged="RefreshInterval_Changed">
                                <ComboBoxItem Content="1 minute" Tag="1" />
                                <ComboBoxItem Content="3 minutes" Tag="3" />
                                <ComboBoxItem Content="5 minutes" Tag="5" />
                                <ComboBoxItem Content="15 minutes" Tag="15" />
                                <ComboBoxItem Content="30 minutes" Tag="30" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock x:Uid="NotificationsTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                    <StackPanel Spacing="14">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock x:Uid="ThresholdLabel" VerticalAlignment="Center" />
                            <ComboBox x:Name="ThresholdBox" Grid.Column="1" MinWidth="150" SelectionChanged="Threshold_Changed">
                                <ComboBoxItem Content="Off" Tag="0" />
                                <ComboBoxItem Content="5%" Tag="5" />
                                <ComboBoxItem Content="10%" Tag="10" />
                                <ComboBoxItem Content="20%" Tag="20" />
                            </ComboBox>
                        </Grid>
                        <ToggleSwitch x:Name="ResetNotificationToggle" x:Uid="ResetNotificationToggle" Toggled="Notification_Toggled" />
                        <ToggleSwitch x:Name="ErrorNotificationToggle" x:Uid="ErrorNotificationToggle" Toggled="Notification_Toggled" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock x:Uid="SystemTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                    <StackPanel Spacing="14">
                        <ToggleSwitch x:Name="StartupToggle" x:Uid="StartupToggle" Toggled="Startup_Toggled" />
                        <TextBlock x:Name="StartupStatus" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock x:Uid="LanguageLabel" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <ComboBox x:Name="LanguageBox" MinWidth="170">
                                    <ComboBoxItem x:Uid="SystemDefaultLanguage" Content="System default" Tag="" />
                                    <ComboBoxItem Content="English" Tag="en-US" />
                                    <ComboBoxItem Content="日本語" Tag="ja-JP" />
                                    <ComboBoxItem Content="简体中文" Tag="zh-Hans" />
                                    <ComboBoxItem Content="한국어" Tag="ko-KR" />
                                </ComboBox>
                                <Button x:Uid="ApplyLanguageButton" Click="ApplyLanguage_Click" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="10">
                <TextBlock x:Uid="DataTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock x:Uid="RetentionLabel" VerticalAlignment="Center" />
                            <ComboBox x:Name="RetentionBox" Grid.Column="1" MinWidth="150" SelectionChanged="Retention_Changed">
                                <ComboBoxItem Content="30 days" Tag="30" />
                                <ComboBoxItem Content="90 days" Tag="90" />
                                <ComboBoxItem Content="180 days" Tag="180" />
                                <ComboBoxItem Content="365 days" Tag="365" />
                            </ComboBox>
                        </Grid>
                        <TextBlock x:Name="DiagnosticText" TextWrapping="Wrap" FontFamily="Consolas"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <HyperlinkButton x:Uid="PrivacyPolicyButton"
                                             NavigateUri="https://github.com/TakeruF/token_meter/blob/main/docs/privacy.md" />
                            <HyperlinkButton x:Uid="DataSourcesButton"
                                             NavigateUri="https://github.com/TakeruF/token_meter/blob/main/docs/data-sources.md" />
                            <HyperlinkButton x:Uid="UninstallButton"
                                             NavigateUri="https://github.com/TakeruF/token_meter/blob/main/docs/windows-uninstall.md" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Uid="CopyDiagnosticsButton" Click="CopyDiagnostics_Click" />
                            <Button x:Uid="DeleteHistoryButton" Click="DeleteHistory_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
