<Page
    x:Class="TokenMeter.Windows.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TokenMeter.Windows">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer>
            <StackPanel Padding="32" Spacing="24" MaxWidth="1180" HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Uid="DashboardTitle" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="{Binding UpdatedAt}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <ComboBox x:Uid="RangeBox" ItemsSource="{Binding Ranges}"
                                  SelectedItem="{Binding SelectedRange, Mode=TwoWay}"
                                  DisplayMemberPath="Label"
                                  MinWidth="140" />
                        <Button x:Uid="RefreshButton" Click="Refresh_Click">
                            <SymbolIcon Symbol="Refresh" />
                        </Button>
                    </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding ProviderCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="300" MinHeight="190" Margin="0,0,12,12" Padding="18"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="10">
                                <StackPanel Spacing="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding TodayTokens}" FontWeight="SemiBold" />
                                    </Grid>
                                    <TextBlock Text="{Binding UsageText}" FontSize="20" FontWeight="SemiBold" />
                                    <ProgressBar Value="{Binding UsagePercent}" Maximum="100" Height="8"
                                                 AutomationProperties.Name="{Binding UsageText}" />
                                    <TextBlock Text="{Binding ResetText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding Status}" TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                        <StackPanel><TextBlock x:Uid="TotalTokensLabel" /><TextBlock Text="{Binding TotalTokens}" FontSize="24" FontWeight="SemiBold" /></StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="16">
                        <StackPanel><TextBlock x:Uid="InputTokensLabel" /><TextBlock Text="{Binding InputTokens}" FontSize="24" FontWeight="SemiBold" /></StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="16">
                        <StackPanel><TextBlock x:Uid="CachedTokensLabel" /><TextBlock Text="{Binding CachedTokens}" FontSize="24" FontWeight="SemiBold" /></StackPanel>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}" Padding="16">
                        <StackPanel><TextBlock x:Uid="OutputTokensLabel" /><TextBlock Text="{Binding OutputTokens}" FontSize="24" FontWeight="SemiBold" /></StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock x:Uid="UsageTrendTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <local:UsageChart x:Name="Chart" x:Uid="UsageChartControl" />
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardBorderStyle}" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock x:Uid="ModelsTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <ListView ItemsSource="{Binding Models}" MaxHeight="340">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="2,6" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <StackPanel><TextBlock Text="{Binding Model}" /><TextBlock Text="{Binding Provider}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Tokens}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock x:Uid="RecentSessionsTitle" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <ListView ItemsSource="{Binding Sessions}" MaxHeight="340">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="2,6" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Provider}" MinWidth="64" />
                                            <StackPanel Grid.Column="1"><TextBlock Text="{Binding Model}" /><TextBlock Text="{Binding When}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right"><TextBlock Text="{Binding Tokens}" /><TextBlock Text="{Binding Turns}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" /></StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
        <ProgressBar x:Name="RefreshProgress" IsIndeterminate="True" VerticalAlignment="Top" Visibility="Collapsed" />
    </Grid>
</Page>
