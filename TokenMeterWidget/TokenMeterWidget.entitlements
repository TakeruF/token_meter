<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The widget is sandboxed. It never reads the CLI logs — only the JSON
	     snapshot the main app writes into the shared App Group container. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.tokenmeter.b97m43j5tt.shared</string>
	</array>
</dict>
</plist>
